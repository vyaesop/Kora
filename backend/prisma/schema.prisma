generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      String               @id @default(uuid())
  email                   String               @unique
  passwordHash            String
  name                    String
  username                String?              @unique
  profileImageUrl         String?
  bio                     String?
  link                    String?
  userType                String
  verificationStatus      String               @default("not_submitted")
  verificationNote        String?
  truckType               String?
  licensePlate            String?
  insurance               String?
  licenseNumberPhoto      String?
  driverTradeLicensePhoto String?
  licenseNumber           String?
  libre                   String?
  tradeLicense            String?
  tradeLicensePhoto       String?
  tradeRegistrationCertificatePhoto String?
  tinNumber               String?
  idPhoto                 String?
  isRepresentative        Boolean              @default(false)
  representativePhoto     String?
  isAdmin                 Boolean              @default(false)
  isSuperAdmin            Boolean              @default(false)
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt
  phoneNumber             String?
  ratingAverage           Float                @default(0)
  ratingCount             Int                  @default(0)
  ratingTotal             Float                @default(0)
  address                 String?
  verificationReviewedAt  DateTime?
  verificationSubmittedAt DateTime?
  bids                    Bid[]                @relation("BidDriver")
  sentChatMessages        ChatMessage[]
  comments                Comment[]
  disputesReported        Dispute[]            @relation("DisputeReporter")
  driverLocation          DriverLocation?
  ratingsReceived         DriverRating[]       @relation("DriverRatings")
  followerList            Follows[]            @relation("Following")
  followingList           Follows[]            @relation("Follower")
  passwordResetTokens     PasswordResetToken[]
  notifications           AppNotification[]
  paymentOrders           PaymentOrder[]
  threads                 Thread[]             @relation("ThreadOwner")
  wallet                  Wallet?
  walletTransactions      WalletTransaction[]
}

model Follows {
  followerId  String
  followingId String
  follower    User   @relation("Following", fields: [followerId], references: [id])
  following   User   @relation("Follower", fields: [followingId], references: [id])

  @@id([followerId, followingId])
}

model Thread {
  id             String        @id @default(uuid())
  ownerId        String
  message        String
  weight         Float?
  category       String?
  type           String?
  start          String?
  end            String?
  packaging      String?
  weightUnit     String?       @default("kg")
  startLat       Float?
  startLng       Float?
  endLat         Float?
  endLng         Float?
  deliveryStatus String?       @default("pending")
  startRegion    String?
  startZone      String?
  startCity      String?
  endRegion      String?
  endZone        String?
  endCity        String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  bids           Bid[]
  chatMessages   ChatMessage[]
  comments       Comment[]
  disputes       Dispute[]
  owner          User          @relation("ThreadOwner", fields: [ownerId], references: [id])
  paymentOrders   PaymentOrder[]
}

model Bid {
  id          String    @id @default(uuid())
  loadId      String
  driverId    String
  amount      Float
  status      String    @default("pending")
  note        String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  acceptedAt  DateTime?
  completedAt DateTime?
  driver      User      @relation("BidDriver", fields: [driverId], references: [id])
  load        Thread    @relation(fields: [loadId], references: [id])
  paymentOrders PaymentOrder[]
}

model Comment {
  id        String   @id @default(uuid())
  threadId  String
  userId    String
  text      String
  createdAt DateTime @default(now())
  thread    Thread   @relation(fields: [threadId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
}

model Dispute {
  id             String   @id @default(uuid())
  threadId       String
  reporterId     String
  category       String
  details        String?
  status         String   @default("open")
  resolutionNote String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  reporter       User     @relation("DisputeReporter", fields: [reporterId], references: [id])
  thread         Thread   @relation(fields: [threadId], references: [id])
}

model ChatMessage {
  id         String   @id @default(uuid())
  threadId   String
  senderId   String
  receiverId String?
  text       String
  createdAt  DateTime @default(now())
  sender     User     @relation(fields: [senderId], references: [id])
  thread     Thread   @relation(fields: [threadId], references: [id])

  @@index([threadId, createdAt])
  @@index([senderId, createdAt])
}

model DriverRating {
  id        String   @id @default(uuid())
  driverId  String
  ownerId   String
  bidId     String   @unique
  rating    Float
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  driver    User     @relation("DriverRatings", fields: [driverId], references: [id])

  @@index([driverId, createdAt])
}

model DriverLocation {
  id        String   @id @default(uuid())
  driverId  String   @unique
  latitude  Float
  longitude Float
  updatedAt DateTime @updatedAt
  driver    User     @relation(fields: [driverId], references: [id])

  @@index([updatedAt])
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id])

  @@index([userId, expiresAt])
  @@index([tokenHash])
}

model TelegramContact {
  id             String   @id @default(uuid())
  phoneNumber    String   @unique
  chatId         String
  telegramUserId String?
  firstName      String?
  lastName       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([phoneNumber])
}

model PhoneOtp {
  id          String    @id @default(uuid())
  phoneNumber String
  codeHash    String
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime  @default(now())

  @@index([phoneNumber, expiresAt])
}

model Wallet {
  id              String              @id @default(uuid())
  userId          String              @unique
  currency        String              @default("ETB")
  balance         Float               @default(0)
  reservedBalance Float               @default(0)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  user            User                @relation(fields: [userId], references: [id])
  paymentOrders   PaymentOrder[]
  transactions    WalletTransaction[]

  @@index([userId])
}

model WalletTransaction {
  id            String   @id @default(uuid())
  walletId      String
  userId        String
  kind          String
  direction     String
  status        String   @default("completed")
  amount        Float
  currency      String   @default("ETB")
  title         String
  description   String?
  referenceType String?
  referenceId   String?
  provider      String?
  providerRef   String?
  metadata      Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  wallet        Wallet   @relation(fields: [walletId], references: [id])
  user          User     @relation(fields: [userId], references: [id])

  @@index([walletId, createdAt])
  @@index([userId, createdAt])
  @@index([referenceType, referenceId])
}

model PaymentOrder {
  id              String   @id @default(uuid())
  userId          String
  walletId        String?
  threadId        String?
  bidId           String?
  type            String
  status          String   @default("pending")
  provider        String
  amount          Float
  currency        String   @default("ETB")
  merchOrderId    String?  @unique
  providerOrderId String?
  prepayId        String?
  checkoutUrl     String?
  rawRequest      String?
  metadata        Json?
  providerPayload Json?
  failureReason   String?
  completedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id])
  wallet          Wallet?  @relation(fields: [walletId], references: [id])
  thread          Thread?  @relation(fields: [threadId], references: [id])
  bid             Bid?     @relation(fields: [bidId], references: [id])

  @@index([userId, createdAt])
  @@index([walletId, createdAt])
  @@index([threadId, createdAt])
  @@index([bidId, createdAt])
  @@index([status, createdAt])
}

model AppNotification {
  id          String   @id @default(uuid())
  userId      String
  type        String
  title       String
  body        String
  entityType  String?
  entityId    String?
  route       String?
  isRead      Boolean  @default(false)
  readAt      DateTime?
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id])

  @@index([userId, isRead, createdAt])
  @@index([userId, createdAt])
}
